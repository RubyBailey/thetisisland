---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import homeCards from "../data/home-cards.yaml";

const page = await getEntry("pages", "home");
const { Content } = await render(page);

const cards = homeCards.cards;
---

<BaseLayout title="Home">
  <section class="relative overflow-hidden">
    <img
      src="/images/hero-sunset.jpg"
      alt="Sunset over the water near Thetis Island"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-black/50 via-black/30 to-black/60"></div>
    <div class="relative mx-auto max-w-3xl px-4 py-24 sm:py-32 text-center text-white">
      <h1 class="text-3xl sm:text-4xl font-bold mb-4 drop-shadow-lg">Welcome to Thetis Island</h1>
      <p class="text-lg drop-shadow-md opacity-95">Your gateway to community services, resources and visitor information for our beautiful Gulf Island.</p>
    </div>
    <p class="relative text-right text-xs text-white/60 px-4 pb-2">Photo by David Greene</p>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-12">
    <h2 class="text-2xl font-bold text-primary mb-8 text-center">Find What You Need</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {cards.map((card) => (
        <a href={card.href} class="bg-surface rounded-lg shadow p-6 hover:shadow-md transition-shadow group">
          <h3 class="font-semibold text-primary mb-2 group-hover:text-accent transition-colors">{card.title}</h3>
          <p class="text-sm text-text-muted">{card.text}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="mx-auto max-w-4xl px-4 pb-12">
    <div class="prose max-w-none text-text">
      <Content />
    </div>
    <a href="/about" class="text-accent font-medium hover:underline">Learn more about TIRRA &rarr;</a>
  </section>
</BaseLayout>
